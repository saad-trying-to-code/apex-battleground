        <div class="card-avatar-dot" style="background:${cls.color};box-shadow:0 0 12px ${cls.color}"></div>
      </div>
      <div class="card-name" style="color:${cls.color};text-shadow:0 0 10px ${cls.color}">${cls.name}</div>
      <div class="card-role">${cls.role}</div>
      <div style="width:100%;margin-bottom:6px">${statBars}</div>
      <div class="card-div"></div>
      <div style="width:100%">${skillRows}</div>`;
    card.addEventListener('click', ()=>{ selectedCharIdx=i; buildCharCards(); AudioMgr.select(); sendMsg({type:'set_class',classId:cls.id}); });
    container.appendChild(card);
  });
}

function confirmSelect() {
  AudioMgr.resumeCtx();
  const cls = CLASSES[selectedCharIdx];
  sendMsg({type:'set_class', classId: cls.id});
  if(Net.isHost) {
    // Host sees a "ready" button; show it after a moment
    document.getElementById('csStatus').textContent='YOU ARE HOST — PRESS ENTER OR CLICK READY';
  } else {
    document.getElementById('csStatus').textContent='CLASS CONFIRMED — WAITING FOR HOST TO START...';
  }
  LocalPlayer.applyClass(cls);
}

// ─── LOBBY UI ─────────────────────────────────────────────────────────────────
function updateLobbyUI() {
  const list = document.getElementById('playerList');
  list.innerHTML = '';
  const slots = Array.from({length:4}, (_,i) => {
    const p = Object.values(Net.lobbyPlayers).find(p=>p.slot===i);
    const col = PLAYER_COLORS[i];
    if(p) return `<div class="player-slot" style="border-color:${col}22">
      <div class="slot-dot" style="background:${col};box-shadow:0 0 10px ${col}"></div>
      <div class="slot-name" style="color:${col}">P${i+1}</div>
      <div class="slot-class">${(p.classId||'brawler').toUpperCase()}</div>
    </div>`;
    return `<div class="player-slot slot-empty" style="border-color:#1a1a1a">
      <div class="slot-dot"></div>
      <div class="slot-name">— OPEN —</div>
    </div>`;
  });
  list.innerHTML = slots.join('');
}

// ─── MESSAGE HANDLER ──────────────────────────────────────────────────────────
function handleMsg(msg) {
  switch(msg.type) {

    case 'room_created':
      Net.myId = msg.playerId;
      Net.mySlot = msg.slot;
      Net.roomCode = msg.code;
      Net.isHost = true;
      Net.hostId = msg.playerId;
      Net.lobbyPlayers[msg.playerId] = { id:msg.playerId, slot:msg.slot, name:`P${msg.slot+1}`, classId:'brawler' };
      showScreen('lobbyScreen');
      document.getElementById('lobbyCode').textContent = msg.code;
      document.getElementById('startGameBtn').style.display = 'block';
      document.getElementById('waitText').style.display = 'none';
      updateLobbyUI();
      break;

    case 'room_joined':
      Net.myId = msg.playerId;
      Net.mySlot = msg.slot;
      Net.roomCode = msg.code;
      Net.isHost = msg.hostId === msg.playerId;
      Net.hostId = msg.hostId;
      Net.lobbyPlayers = {};
      for(const p of (msg.existingPlayers||[])) Net.lobbyPlayers[p.id]=p;
      Net.lobbyPlayers[msg.playerId] = { id:msg.playerId, slot:msg.slot, name:`P${msg.slot+1}`, classId:'brawler' };
      showScreen('lobbyScreen');
      document.getElementById('lobbyCode').textContent = msg.code;
      if(Net.isHost){ document.getElementById('startGameBtn').style.display='block'; document.getElementById('waitText').style.display='none'; }
      updateLobbyUI();
      break;

    case 'player_joined':
      Net.lobbyPlayers[msg.player.id] = msg.player;
      updateLobbyUI();
      addChat(`P${msg.player.slot+1} joined the room`, PLAYER_COLORS[msg.player.slot]);
      break;

    case 'player_left':
      const lp = Net.lobbyPlayers[msg.playerId];
      if(lp) addChat(`[P${lp.slot+1}] disconnected`, '#666');
      delete Net.lobbyPlayers[msg.playerId];
      delete Game.serverPlayers[msg.playerId];
      updateLobbyUI();
      // Update leaderboard/hp stack
      if(Game.phase==='playing') {
        updateHpStack(Game.serverPlayers);
        updateLeaderboard(Game.serverPlayers);
      }
      break;

    case 'host_changed':
      Net.hostId = msg.newHostId;
      Net.isHost = msg.newHostId === Net.myId;
      if(Net.isHost) {
        document.getElementById('startGameBtn').style.display='block';
        document.getElementById('waitText').style.display='none';
        addChat('You are now the host', '#ffcc44');
        if(Game.phase==='gameover') document.getElementById('playAgainBtn').style.display='block';
      }
      break;

    case 'player_class_changed':
      if(Net.lobbyPlayers[msg.playerId]) Net.lobbyPlayers[msg.playerId].classId = msg.classId;
      updateLobbyUI();
      break;

    case 'game_started':
      obstacles = genObstacles(msg.seed);
      Game.serverPlayers = msg.players;
      Game.serverEnemies = [];
      Game.phase = 'playing';
      Game.elapsed = 0;
      // Apply our class
      const myCls = CLASSES.find(c=>c.id===(Net.lobbyPlayers[Net.myId]?.classId||'brawler')) || CLASSES[0];
      LocalPlayer.reset();
      LocalPlayer.applyClass(myCls);
      if(msg.players[Net.myId]) { LocalPlayer.x=msg.players[Net.myId].x; LocalPlayer.y=msg.players[Net.myId].y; }
      LocalPlayer.hp = myCls.hp; LocalPlayer.maxHp = myCls.hp;
      // Show game
      showScreen(null);
      document.getElementById('leaderboard').style.display='block';
      document.getElementById('hpStack').style.display='flex';
      AudioMgr.resumeCtx();
      break;

    case 'game_state':
      Game.serverPlayers = msg.players;
      Game.serverEnemies = msg.enemies;
      Game.elapsed = msg.elapsed;
      // Reconcile our HP from server
      const me = msg.players[Net.myId];
      if(me){
        LocalPlayer.hp = me.hp;
        LocalPlayer.kills = me.kills;
        LocalPlayer.level = me.level;
        LocalPlayer.xp = me.xp;
        LocalPlayer.xpToNext = me.xpToNext;
        LocalPlayer.dmgMult = me.dmgMult;
        LocalPlayer.speed = me.speed;
        if(me.dead && !LocalPlayer.dead) LocalPlayer.dead = true;
      }
      updateHpStack(msg.players);
      updateLeaderboard(msg.players);
      break;

    case 'enemy_hit':
      // Local visual feedback
      const hitEnemy = Game.serverEnemies.find(e=>e.id===msg.enemyId);
      if(hitEnemy){
        DmgNums.spawn(hitEnemy.x, hitEnemy.y-10, msg.crit?`CRIT ${msg.dmg}!`:msg.dmg, msg.crit?'#ffcc00':'#fff', msg.crit);
      }
      break;

    case 'enemy_killed':
      const ke = Game.serverEnemies.find(e=>e.id===msg.enemyId);
      if(ke){ Particles.spawn(ke.x,ke.y,['#fff','#ffdd00','#ff8800','#ff2200'][ke.tier],20,7,35,4); AudioMgr.enemyDeath(); }
      const kp = Game.serverPlayers[msg.killerId];
      if(kp) addKillFeed(`P${(kp.slot||0)+1} killed enemy (${msg.killerKills} kills)`);
      if(msg.killerId===Net.myId) LocalPlayer.levelUpFlash = 0; // reset (levelup flash handled by server state)
      break;

    case 'player_hit':
      if(msg.playerId === Net.myId){ LocalPlayer.takeDamage(msg.amount); }
      else {
        const hp = Game.serverPlayers[msg.playerId];
        if(hp){ DmgNums.spawn(hp.x,hp.y-30,`-${msg.amount}`,'#ff6666',false); }
      }
      break;

    case 'player_died':
      if(msg.playerId===Net.myId){ LocalPlayer.dead=true; AudioMgr.playerHurt(); }
      else {
        const dp = Game.serverPlayers[msg.playerId];
        const slot = dp?.slot ?? 0;
        addChat(`[P${slot+1}] was defeated`, '#ff4444');
      }
      break;

    case 'game_over':
      Game.phase = 'gameover';
      showGameOver(msg.scores);
      break;

    case 'chat':
      addChat(`P${msg.slot+1}: ${msg.text}`, PLAYER_COLORS[msg.slot]||'#aaa');
      break;

    case 'back_to_lobby':
      Game.phase = 'lobby';
      showScreen('lobbyScreen');
      document.getElementById('leaderboard').style.display='none';
      document.getElementById('hpStack').style.display='none';
      // Show char select for class re-selection
      setTimeout(()=>{
        showScreen('charSelectScreen');
        buildCharCards();
        if(Net.isHost) document.getElementById('csStatus').textContent='PRESS ENTER TO START';
        else document.getElementById('csStatus').textContent='WAITING FOR HOST TO START...';
      }, 500);
      break;

    case 'error':
      setMenuErr(msg.message);
      showConnecting(false);
      break;
  }
}

function showGameOver(scores) {
  document.getElementById('leaderboard').style.display='none';
  document.getElementById('hpStack').style.display='none';

  const sb = document.getElementById('finalScoreboard');
  sb.innerHTML = scores.map((s,i) => {
    const col = PLAYER_COLORS[s.slot] || '#fff';
    const el = Math.floor(s.timeSurvived/60), mm=Math.floor(el/60), ss=el%60;
    const medal = i===0?'🥇':i===1?'🥈':i===2?'🥉':'';
    return `<div class="score-row">
      <div class="score-dot" style="background:${col};box-shadow:0 0 8px ${col}"></div>
      <span class="score-label" style="color:${col}">${medal} P${s.slot+1}</span>
      <span class="score-val">${s.kills} KILLS · ${mm}:${String(ss).padStart(2,'0')}</span>
    </div>`;
  }).join('');

  if(Net.isHost) document.getElementById('playAgainBtn').style.display='block';
  else document.getElementById('playAgainBtn').style.display='none';
  showScreen('gameOverScreen');
}

function handleDisconnect() {
  if(Game.phase==='playing'||Game.phase==='lobby'){
    setMenuErr('Disconnected from server.');
    Game.phase='menu';
    showScreen('menuScreen');
    document.getElementById('leaderboard').style.display='none';
    document.getElementById('hpStack').style.display='none';
  }
}

// ─── GAME OBJECT ──────────────────────────────────────────────────────────────
const Game = {
  phase: 'menu',
  elapsed: 0,
  serverPlayers: {},
  serverEnemies: []
};

// ─── SCREEN HELPER ────────────────────────────────────────────────────────────
function showScreen(id) {
  ['menuScreen','lobbyScreen','charSelectScreen','gameOverScreen'].forEach(s=>{
    document.getElementById(s).style.display = s===id?'flex':'none';
  });
}

// ─── MAIN LOOP ────────────────────────────────────────────────────────────────
function loop() {
  requestAnimationFrame(loop);
  if(Game.phase === 'playing') {
    const camTarget = LocalPlayer.dead
      ? { x: WORLD_W/2, y: WORLD_H/2 }
      : { x: LocalPlayer.x, y: LocalPlayer.y };
    Camera.update(camTarget.x, camTarget.y);

    if(!LocalPlayer.dead) LocalPlayer.update();

    updateProjs(); updateDelayed(); updateEffects(); Particles.update(); DmgNums.update();

    drawWorld();
    drawEffects();
    Particles.draw();
    drawProjectiles();
    drawServerEnemies(Game.serverEnemies);
    drawRemotePlayers(Game.serverPlayers);
    if(!LocalPlayer.dead) LocalPlayer.draw();
    DmgNums.draw();
    drawLocalHUD();
    Input.endFrame();
  } else {
    ctx.fillStyle='#000'; ctx.fillRect(0,0,canvas.width,canvas.height);
  }
}

// ─── EVENT WIRING ─────────────────────────────────────────────────────────────
document.getElementById('createRoomBtn').addEventListener('click', ()=>{
  AudioMgr.init(); AudioMgr.resumeCtx();
  connect(()=>sendMsg({type:'create_room'}));
});

document.getElementById('joinRoomBtn').addEventListener('click', ()=>{
  const code = document.getElementById('joinCodeInput').value.trim().toUpperCase();
  if(code.length !== 4){ setMenuErr('Enter a 4-character room code'); return; }
  setMenuErr('');
  AudioMgr.init(); AudioMgr.resumeCtx();
  connect(()=>sendMsg({type:'join_room',code}));
});

document.getElementById('joinCodeInput').addEventListener('keydown', e=>{
  if(e.key==='Enter') document.getElementById('joinRoomBtn').click();
});

document.getElementById('startGameBtn').addEventListener('click', ()=>{
  showScreen('charSelectScreen');
  buildCharCards();
  document.getElementById('csStatus').textContent='SELECT CLASS — PRESS ENTER TO START';
});

document.getElementById('leaveLobbyBtn').addEventListener('click', ()=>{
  if(ws) ws.close();
  Net.lobbyPlayers={};
  showScreen('menuScreen');
});

document.getElementById('playAgainBtn').addEventListener('click', ()=>{
  sendMsg({type:'play_again'});
});

document.getElementById('backToMenuBtn').addEventListener('click', ()=>{
  if(ws) ws.close();
  Game.phase='menu';
  showScreen('menuScreen');
  document.getElementById('leaderboard').style.display='none';
  document.getElementById('hpStack').style.display='none';
});

window.addEventListener('keydown', e=>{
  if(Game.phase==='menu'||Game.phase==='charselect'||document.getElementById('charSelectScreen').style.display==='flex'){
    const csVisible = document.getElementById('charSelectScreen').style.display==='flex';
    if(csVisible){
      if(e.code==='ArrowLeft'||e.code==='ArrowRight'){
        AudioMgr.resumeCtx(); AudioMgr.select();
        selectedCharIdx=(selectedCharIdx+(e.code==='ArrowRight'?1:-1)+CLASSES.length)%CLASSES.length;
        buildCharCards();
        sendMsg({type:'set_class',classId:CLASSES[selectedCharIdx].id});
      }
      if(e.code==='Enter'){
        AudioMgr.resumeCtx();
        confirmSelect();
        if(Net.isHost) sendMsg({type:'start_game'});
      }
    }
  }
  if(e.code==='Enter' && Game.phase==='gameover' && Net.isHost){
    sendMsg({type:'play_again'});
  }
});

// ─── INIT ─────────────────────────────────────────────────────────────────────
Input.init();
AudioMgr.init();
showScreen('menuScreen');
loop();
</script>
