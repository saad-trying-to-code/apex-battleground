function drawLocalHUD() {
  const p = LocalPlayer;
  const col = PLAYER_COLORS[Net.mySlot];
  const pad = 18;

  // Stamina bar
  const stY = pad, stW = 160, stH = 10;
  ctx.fillStyle='rgba(0,0,0,0.6)'; ctx.fillRect(pad-2,stY-2,stW+4,stH+4);
  ctx.fillStyle='#001133'; ctx.fillRect(pad,stY,stW,stH);
  ctx.fillStyle='#2266ff'; ctx.shadowColor='#4488ff'; ctx.shadowBlur=6;
  ctx.fillRect(pad,stY,stW*(p.stamina/p.maxStamina),stH); ctx.shadowBlur=0;
  ctx.fillStyle='#aaa'; ctx.font='9px Courier New';
  ctx.fillText(`STA ${Math.ceil(p.stamina)}`,pad+4,stY+8);

  // XP bar
  const xpY=stY+stH+6, xpW=200, xpH=10;
  ctx.fillStyle='rgba(0,0,0,0.6)'; ctx.fillRect(pad-2,xpY-2,xpW+4,xpH+4);
  ctx.fillStyle='#221100'; ctx.fillRect(pad,xpY,xpW,xpH);
  ctx.fillStyle='#ffaa00'; ctx.shadowColor='#ffcc00'; ctx.shadowBlur=6;
  ctx.fillRect(pad,xpY,xpW*(p.xp/p.xpToNext),xpH); ctx.shadowBlur=0;
  ctx.fillStyle='#ffcc00'; ctx.font='bold 10px Courier New';
  ctx.fillText(`LVL ${p.level}  XP ${p.xp}/${p.xpToNext}`,pad+4,xpY+8);

  // Class name
  const cls=CLASSES.find(c=>c.id===p.classId)||CLASSES[0];
  ctx.fillStyle=col; ctx.font='bold 9px Courier New'; ctx.shadowColor=col; ctx.shadowBlur=6;
  ctx.fillText(`[ ${cls.name} ]`,pad,xpY+xpH+13); ctx.shadowBlur=0;

  // Status
  let sY=xpY+xpH+24;
  if(p.rageMode){ctx.fillStyle='#ff4400';ctx.font='bold 10px Courier New';ctx.shadowColor='#ff4400';ctx.shadowBlur=8;ctx.fillText('⚡ RAGE MODE',pad,sY);ctx.shadowBlur=0;sY+=13;}
  if(p.smokeMode){ctx.fillStyle='#aa22ff';ctx.font='bold 10px Courier New';ctx.shadowColor='#aa22ff';ctx.shadowBlur=8;ctx.fillText('👁 INVISIBLE',pad,sY);ctx.shadowBlur=0;sY+=13;}
  if(p.ironFort){ctx.fillStyle='#ffcc00';ctx.font='bold 10px Courier New';ctx.shadowColor='#ffcc00';ctx.shadowBlur=8;ctx.fillText('🛡 IRON FORTRESS',pad,sY);ctx.shadowBlur=0;}

  // Skills bar
  const skillsY=canvas.height-80;
  const sd=p.classSkills.length>0?[
    {key:'Q',name:p.classSkills[0].name,cd:p.classSkills[0].cd,cur:p.skills.Q,color:p.classSkills[0].color},
    {key:'E',name:p.classSkills[1].name,cd:p.classSkills[1].cd,cur:p.skills.E,color:p.classSkills[1].color},
    {key:'R',name:p.classSkills[2].name,cd:p.classSkills[2].cd,cur:p.skills.R,color:p.classSkills[2].color},
    {key:'⎵',name:'DODGE',cd:120,cur:p.dodgeCooldown,color:'#44ffcc'}
  ]:[];
  const bSz=56, gap=8, totW=sd.length*(bSz+gap)-gap, stX2=(canvas.width-totW)/2;
  sd.forEach((s,i)=>{
    const bx=stX2+i*(bSz+gap), ready=s.cur===0;
    ctx.fillStyle=ready?'rgba(0,0,0,0.7)':'rgba(0,0,0,0.88)';
    ctx.strokeStyle=s.color+(ready?'ff':'44'); ctx.lineWidth=2;
    ctx.shadowColor=ready?s.color:'transparent'; ctx.shadowBlur=ready?10:0;
    ctx.beginPath(); ctx.roundRect(bx,skillsY,bSz,bSz,6); ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;
    if(!ready){
      ctx.fillStyle='rgba(0,0,0,0.55)'; const pct=s.cur/s.cd;
      ctx.fillRect(bx,skillsY+bSz*(1-pct),bSz,bSz*pct);
      ctx.fillStyle='#fff'; ctx.font='bold 12px Courier New'; ctx.textAlign='center';
      ctx.fillText((s.cur/60).toFixed(1)+'s',bx+bSz/2,skillsY+bSz/2+5);
    }
    ctx.fillStyle=ready?s.color:'#555'; ctx.font='bold 15px Courier New'; ctx.textAlign='center';
    ctx.fillText(s.key,bx+bSz/2,skillsY+24);
    ctx.fillStyle='#666'; ctx.font='7px Courier New';
    ctx.fillText(s.name.slice(0,9),bx+bSz/2,skillsY+bSz-7);
    ctx.textAlign='left';
  });

  // Timer / kills
  const el=Math.floor(Game.elapsed/60), mm=Math.floor(el/60), ss=el%60;
  ctx.fillStyle='#ff6600'; ctx.font='bold 16px Courier New'; ctx.textAlign='right';
  ctx.shadowColor='#ff4400'; ctx.shadowBlur=10;
  ctx.fillText(`KILLS: ${p.kills}`,canvas.width-200-pad,pad+20);
  ctx.fillStyle='#888'; ctx.font='13px Courier New'; ctx.shadowBlur=0;
  ctx.fillText(`${mm}:${ss.toString().padStart(2,'0')}`,canvas.width-200-pad,pad+40);
  ctx.textAlign='left';

  // Minimap
  const mmX=canvas.width-130-pad, mmY2=canvas.height-130-pad;
  ctx.fillStyle='rgba(0,0,0,0.7)'; ctx.strokeStyle='#333'; ctx.lineWidth=1;
  ctx.fillRect(mmX,mmY2,120,120); ctx.strokeRect(mmX,mmY2,120,120);
  // All players on minimap
  for(const [id,sp] of Object.entries(Game.serverPlayers)){
    if(sp.dead) continue;
    const dx=mmX+(sp.x/WORLD_W)*120, dy=mmY2+(sp.y/WORLD_H)*120;
    ctx.fillStyle=PLAYER_COLORS[sp.slot]; ctx.beginPath(); ctx.arc(dx,dy,3,0,Math.PI*2); ctx.fill();
  }
  // Enemies
  Game.serverEnemies.forEach(e=>{
    if(e.dead) return;
    const ex=mmX+(e.x/WORLD_W)*120, ey=mmY2+(e.y/WORLD_H)*120;
    ctx.fillStyle=e.tier===3?'#ff0000':'#ff6600';
    ctx.beginPath(); ctx.arc(ex,ey,e.tier===3?3:2,0,Math.PI*2); ctx.fill();
  });

  // Level up flash
  if(p.levelUpFlash>0){
    const a=p.levelUpFlash/90;
    ctx.fillStyle=`rgba(255,200,0,${a*0.25})`; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle=`rgba(255,220,50,${a})`; ctx.font=`bold ${70+(1-a)*20}px Courier New`;
    ctx.textAlign='center'; ctx.shadowColor='#ffcc00'; ctx.shadowBlur=30;
    ctx.fillText('LEVEL UP!',canvas.width/2,canvas.height/2);
    ctx.shadowBlur=0; ctx.textAlign='left'; p.levelUpFlash--;
  }

  if(p.dead){
    ctx.fillStyle='rgba(0,0,0,0.55)'; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle='#ff4444'; ctx.font='bold 48px Courier New'; ctx.textAlign='center'; ctx.shadowColor='#ff0000'; ctx.shadowBlur=30;
    ctx.fillText('YOU DIED',canvas.width/2,canvas.height/2-20); ctx.shadowBlur=0;
    ctx.fillStyle='#666'; ctx.font='16px Courier New';
    ctx.fillText('WAITING FOR OTHERS...',canvas.width/2,canvas.height/2+30);
    ctx.textAlign='left';
  }

  if(p.blocking){
    ctx.fillStyle='rgba(68,136,255,0.10)'; ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.strokeStyle='rgba(68,136,255,0.3)'; ctx.lineWidth=3; ctx.strokeRect(2,2,canvas.width-4,canvas.height-4);
  }
}

// ─── CHAT / KILL FEED ─────────────────────────────────────────────────────────
function addChat(text, color='#aaa') {
