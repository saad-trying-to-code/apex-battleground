      this.invincible=Math.max(this.invincible,1);
    } else { this.x+=dx*spd; this.y+=dy*spd; }

    this.x=Math.max(ARENA_MARGIN+this.radius,Math.min(WORLD_W-ARENA_MARGIN-this.radius,this.x));
    this.y=Math.max(ARENA_MARGIN+this.radius,Math.min(WORLD_H-ARENA_MARGIN-this.radius,this.y));
