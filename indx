<script>
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth; canvas.height = window.innerHeight;
window.addEventListener('resize', () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; });

// ─── CONSTANTS ────────────────────────────────────────────────────────────────
const WORLD_W = 3000, WORLD_H = 3000, ARENA_MARGIN = 60;
const PLAYER_COLORS = ['#4488ff','#44ff88','#ff8844','#ff44cc'];
const PLAYER_GLOW   = ['#2255cc','#22cc55','#cc5522','#cc2288'];
const PLAYER_AURA   = ['rgba(68,136,255,0.2)','rgba(68,255,136,0.2)','rgba(255,136,68,0.2)','rgba(255,68,204,0.2)'];

// ─── CLASS DEFINITIONS ────────────────────────────────────────────────────────
const CLASSES = [
  {
    id:'brawler', name:'BRAWLER', role:'TANK FIGHTER',
    color:'#ff3333', glowColor:'#ff1100', auraColor:'rgba(255,40,0,0.22)',
    hp:400, speed:2.8, dmgMult:1.5, defense:0.7, critChance:0.08,
    stats:{HP:90,SPD:28,DMG:92,DEF:72},
    skills:[
      {key:'Q',name:'GROUND POUND',  color:'#ff4400',cd:420,desc:'Massive AOE shockwave, 160px radius'},
      {key:'E',name:'RAGE MODE',     color:'#ff8800',cd:600,desc:'Doubles damage for 5 seconds'},
      {key:'R',name:'SHOCKWAVE FIST',color:'#ffaa00',cd:300,desc:'Piercing projectile punch'}
    ]
  },
  {
    id:'assassin', name:'ASSASSIN', role:'SPEED STRIKER',
    color:'#cc44ff', glowColor:'#9911ee', auraColor:'rgba(180,0,255,0.18)',
    hp:180, speed:5.2, dmgMult:1.1, defense:1.0, critChance:0.35,
    stats:{HP:22,SPD:96,DMG:58,DEF:32},
    skills:[
      {key:'Q',name:'SHADOW STEP', color:'#aa22ff',cd:300,desc:'Teleport behind nearest enemy'},
      {key:'E',name:'SMOKE BOMB',  color:'#7722cc',cd:480,desc:'Invisible + untouchable for 2s'},
      {key:'R',name:'BLADE FLURRY',color:'#dd88ff',cd:360,desc:'6 rapid strikes in succession'}
    ]
  },
  {
    id:'mage', name:'MAGE', role:'ARCANE CASTER',
    color:'#44aaff', glowColor:'#0066ff', auraColor:'rgba(0,120,255,0.2)',
    hp:250, speed:3.2, dmgMult:1.3, defense:0.9, critChance:0.12,
    stats:{HP:48,SPD:54,DMG:76,DEF:48},
    skills:[
      {key:'Q',name:'METEOR STRIKE',color:'#ff6622',cd:480,desc:'Delayed impact, 120px explosion'},
      {key:'E',name:'ICE WALL',     color:'#88ddff',cd:360,desc:'Freeze all nearby enemies 2s'},
      {key:'R',name:'ARCANE BURST', color:'#4488ff',cd:300,desc:'Bouncing chain projectile (x4)'}
    ]
  },
  {
    id:'tank', name:'TANK', role:'IRON GUARDIAN',
    color:'#ffdd00', glowColor:'#ffaa00', auraColor:'rgba(255,200,0,0.15)',
    hp:550, speed:2.3, dmgMult:0.9, defense:0.5, critChance:0.05,
    stats:{HP:100,SPD:18,DMG:44,DEF:100},
    skills:[
      {key:'Q',name:'SHIELD BASH',     color:'#ffcc00',cd:300,desc:'Forward smash, stuns 2s'},
      {key:'E',name:'IRON FORTRESS',   color:'#ffaa00',cd:600,desc:'Full invulnerability 2s'},
      {key:'R',name:'EARTHQUAKE STOMP',color:'#ff8800',cd:480,desc:'Slows all enemies 60% for 3s'}
    ]
  }
];

// ─── SEEDED RNG (matches server) ──────────────────────────────────────────────
function mulberry32(seed) {
  return function() {
    seed |= 0; seed = seed + 0x6D2B79F5 | 0;
    let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

function genObstacles(seed) {
  const rng = mulberry32(seed);
  const obs = [];
  for (let i = 0; i < 13; i++) {
    for (let a = 0; a < 80; a++) {
      const x = ARENA_MARGIN + rng() * (WORLD_W - ARENA_MARGIN * 2);
      const y = ARENA_MARGIN + rng() * (WORLD_H - ARENA_MARGIN * 2);
      const r = 30 + rng() * 40;
      if (Math.hypot(x - WORLD_W/2, y - WORLD_H/2) < 200) continue;
      if (!obs.some(o => Math.hypot(x - o.x, y - o.y) < r + o.r + 30)) { obs.push({x, y, r}); break; }
    }
  }
  return obs;
}

// ─── AUDIO ────────────────────────────────────────────────────────────────────
const AudioMgr = (() => {
  let actx = null;
  const init = () => { if (!actx) actx = new (window.AudioContext || window.webkitAudioContext)(); };
  const resumeCtx = () => { if (actx && actx.state === 'suspended') actx.resume(); };
  function tone(freq, dur, vol=0.3, type='square') {
    if (!actx) return;
    const o = actx.createOscillator(), g = actx.createGain();
    o.connect(g); g.connect(actx.destination);
    o.type = type; o.frequency.setValueAtTime(freq, actx.currentTime);
    g.gain.setValueAtTime(vol, actx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + dur);
    o.start(); o.stop(actx.currentTime + dur);
  }
  function sweep(s, e, dur, vol=0.3, type='sawtooth') {
    if (!actx) return;
    const o = actx.createOscillator(), g = actx.createGain();
    o.connect(g); g.connect(actx.destination); o.type = type;
    o.frequency.setValueAtTime(s, actx.currentTime);
    o.frequency.exponentialRampToValueAtTime(e, actx.currentTime + dur);
    g.gain.setValueAtTime(vol, actx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + dur);
    o.start(); o.stop(actx.currentTime + dur);
  }
  return {
    init, resumeCtx,
    punch()       { tone(180,0.08,0.4,'square'); tone(80,0.12,0.3,'sawtooth'); },
    heavyPunch()  { tone(120,0.1,0.5,'square'); sweep(200,60,0.15,0.4); },
    groundSlam()  { sweep(300,40,0.4,0.5,'sawtooth'); tone(60,0.5,0.4,'sine'); },
    dashStrike()  { sweep(400,800,0.1,0.3,'square'); tone(300,0.15,0.3); },
    energyBurst() { sweep(200,600,0.2,0.4,'sine'); sweep(600,100,0.3,0.3,'sawtooth'); },
    dodge()       { sweep(500,900,0.08,0.2,'sine'); },
    enemyDeath()  { sweep(300,50,0.3,0.35,'sawtooth'); },
    levelUp()     { [261,329,392,523].forEach((f,i)=>setTimeout(()=>tone(f,0.3,0.3,'sine'),i*80)); },
    playerHurt()  { tone(80,0.2,0.5,'sawtooth'); },
    block()       { tone(400,0.06,0.2,'square'); },
    select()      { sweep(300,500,0.1,0.2,'sine'); }
  };
})();

// ─── INPUT ────────────────────────────────────────────────────────────────────
const Input = {
  keys:{}, mouseX:0, mouseY:0, mouseDown:false, mouseJustDown:false,
  init() {
    window.addEventListener('keydown', e => {
      if (!e.repeat) {
        if (!this.keys[e.code]) this.keys[e.code]={down:true,just:true};
        else { this.keys[e.code].down=true; this.keys[e.code].just=true; }
      } else {
        if (!this.keys[e.code]) this.keys[e.code]={down:true,just:false};
        else this.keys[e.code].down=true;
      }
      if (['Space','KeyQ','KeyE','KeyR','ShiftLeft','ShiftRight','KeyW','KeyA','KeyS','KeyD','KeyZ'].includes(e.code)) e.preventDefault();
    });
    window.addEventListener('keyup', e => { if(this.keys[e.code]){this.keys[e.code].down=false;this.keys[e.code].just=false;} });
    window.addEventListener('mousemove', e => { this.mouseX=e.clientX; this.mouseY=e.clientY; });
    window.addEventListener('mousedown', e => { e.preventDefault(); if(e.button===0){this.mouseDown=true;this.mouseJustDown=true;} });
    window.addEventListener('mouseup', e => { e.preventDefault(); if(e.button===0)this.mouseDown=false; });
    window.addEventListener('contextmenu', e => e.preventDefault());
    window.addEventListener('blur', () => { this.keys={}; this.mouseDown=false; this.mouseJustDown=false; });
  },
  isDown(c)  { return !!(this.keys[c]&&this.keys[c].down); },
  justDown(c){ if(this.keys[c]&&this.keys[c].just){this.keys[c].just=false;return true;}return false; },
  consumeMouseDown(){ const v=this.mouseJustDown; this.mouseJustDown=false; return v; },
  endFrame(){ Object.values(this.keys).forEach(k=>{if(k)k.just=false;}); this.mouseJustDown=false; }
};

// ─── CAMERA ───────────────────────────────────────────────────────────────────
const Camera = {
  x:0, y:0, shakeAmt:0, shakeDur:0,
  update(px,py){
    this.x+=(px-canvas.width/2-this.x)*0.12;
    this.y+=(py-canvas.height/2-this.y)*0.12;
    this.x=Math.max(0,Math.min(WORLD_W-canvas.width,this.x));
    this.y=Math.max(0,Math.min(WORLD_H-canvas.height,this.y));
    if(this.shakeDur>0)this.shakeDur--;else this.shakeAmt=0;
  },
  shake(a,d){ this.shakeAmt=Math.max(this.shakeAmt,a); this.shakeDur=Math.max(this.shakeDur,d); },
  worldToScreen(wx,wy){
    let sx=wx-this.x,sy=wy-this.y;
    if(this.shakeDur>0){sx+=(Math.random()-0.5)*this.shakeAmt;sy+=(Math.random()-0.5)*this.shakeAmt;}
    return[sx,sy];
  }
};

// ─── PARTICLES ────────────────────────────────────────────────────────────────
const Particles = {
  pool:[],
  spawn(x,y,color,count,speed,life,size=3){
    for(let i=0;i<count;i++){
      const a=Math.random()*Math.PI*2,s=speed*(0.4+Math.random()*0.8);
      this.pool.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,color,life,maxLife:life,size:size*(0.5+Math.random()*0.7)});
    }
  },
  spawnDir(x,y,angle,spread,color,count,speed,life){
    for(let i=0;i<count;i++){
      const a=angle+(Math.random()-0.5)*spread,s=speed*(0.5+Math.random());
      this.pool.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,color,life,maxLife:life,size:2+Math.random()*3});
    }
  },
  update(){ this.pool=this.pool.filter(p=>{p.x+=p.vx;p.y+=p.vy;p.vx*=0.92;p.vy*=0.92;p.life--;return p.life>0;}); },
  draw(){
    this.pool.forEach(p=>{
      const[sx,sy]=Camera.worldToScreen(p.x,p.y);
      ctx.globalAlpha=p.life/p.maxLife;
      ctx.fillStyle=p.color;
      ctx.beginPath();ctx.arc(sx,sy,p.size*(p.life/p.maxLife),0,Math.PI*2);ctx.fill();
    });
    ctx.globalAlpha=1;
  }
};

// ─── DAMAGE NUMBERS ───────────────────────────────────────────────────────────
const DmgNums = {
  pool:[],
  spawn(x,y,val,color='#fff',big=false){this.pool.push({x,y:y-20,vy:-1.5,val,color,life:60,maxLife:60,big});},
  update(){this.pool=this.pool.filter(d=>{d.y+=d.vy;d.vy*=0.95;d.life--;return d.life>0;});},
  draw(){
    this.pool.forEach(d=>{
      const[sx,sy]=Camera.worldToScreen(d.x,d.y);
      ctx.globalAlpha=Math.min(1,d.life/20);
      ctx.fillStyle=d.color;ctx.font=`bold ${d.big?20:14}px 'Courier New'`;
      ctx.textAlign='center';ctx.shadowColor=d.color;ctx.shadowBlur=8;
      ctx.fillText(d.val,sx,sy);ctx.shadowBlur=0;
    });
    ctx.globalAlpha=1;ctx.textAlign='left';
  }
};

// ─── EFFECTS ──────────────────────────────────────────────────────────────────
const effects = [];
function updateEffects(){
  for(let i=effects.length-1;i>=0;i--){
    const e=effects[i];e.life--;
    if(e.type==='ring')e.r+=(e.maxR-e.r)*0.25;
    if(e.life<=0)effects.splice(i,1);
  }
}
function drawEffects(){
  effects.forEach(e=>{
    const[sx,sy]=Camera.worldToScreen(e.x,e.y);
    ctx.globalAlpha=(e.life/e.maxLife)*0.7;
    ctx.strokeStyle=e.color;ctx.lineWidth=3;ctx.shadowColor=e.color;ctx.shadowBlur=15;
    ctx.beginPath();ctx.arc(sx,sy,e.r,0,Math.PI*2);ctx.stroke();ctx.shadowBlur=0;
  });
  ctx.globalAlpha=1;
}

// ─── DELAYED EFFECTS ──────────────────────────────────────────────────────────
const delayed = [];
function updateDelayed(){
  for(let i=delayed.length-1;i>=0;i--){
    const d=delayed[i];d.timer--;
    if(d.timer<=0){
      if(d.type==='meteor'){
        explodeAt(d.x,d.y,d.r,d.dmg,'player',d.color);
        Camera.shake(14,18);Particles.spawn(d.x,d.y,'#ff8844',40,8,45,5);
      }
      delayed.splice(i,1);
    }
  }
}

// ─── OBSTACLES ────────────────────────────────────────────────────────────────
let obstacles = [];
function circleVsObs(x,y,r){
  for(const o of obstacles){
    const d=Math.hypot(x-o.x,y-o.y);
    if(d<r+o.r){const a=Math.atan2(y-o.y,x-o.x);return{nx:Math.cos(a),ny:Math.sin(a),push:r+o.r-d};}
  }
  return null;
}

// ─── PROJECTILES ──────────────────────────────────────────────────────────────
const projectiles=[];
function spawnProj(x,y,vx,vy,dmg,rad,color,owner,explR,bounces=0){
  projectiles.push({x,y,vx,vy,dmg,rad,color,owner,explR,life:130,hit:false,bounces,bc:0});
}
function updateProjs(){
  for(let i=projectiles.length-1;i>=0;i--){
    const p=projectiles[i];
    p.x+=p.vx;p.y+=p.vy;p.life--;
    if(p.x<ARENA_MARGIN||p.x>WORLD_W-ARENA_MARGIN||p.y<ARENA_MARGIN||p.y>WORLD_H-ARENA_MARGIN)p.hit=true;
    for(const o of obstacles){if(Math.hypot(p.x-o.x,p.y-o.y)<p.rad+o.r)p.hit=true;}

    if(p.bounces>0&&p.owner==='player'&&!p.hit){
      Game.serverEnemies.forEach(e=>{
        if(!e.dead&&Math.hypot(p.x-e.x,p.y-e.y)<p.rad+e.radius+8){
          sendHit([e.id], p.dmg / (LocalPlayer.dmgMult||1));
          p.bc++;
          if(p.bc>=p.bounces){p.hit=true;return;}
          let near=null,nd=Infinity;
          Game.serverEnemies.forEach(e2=>{if(e2===e||e2.dead)return;const d=Math.hypot(p.x-e2.x,p.y-e2.y);if(d<nd){nd=d;near=e2;}});
          if(near){const a=Math.atan2(near.y-p.y,near.x-p.x),s=Math.hypot(p.vx,p.vy);p.vx=Math.cos(a)*s;p.vy=Math.sin(a)*s;}
        }
      });
    }

    if(p.hit||p.life<=0){
      if(p.hit&&p.explR>0)explodeAt(p.x,p.y,p.explR,p.dmg,p.owner,p.color);
      projectiles.splice(i,1);
    }
  }
}
function explodeAt(x,y,r,dmg,owner,color){
  Particles.spawn(x,y,color,30,6,40,5);Camera.shake(8,10);
  if(owner==='player'){
    const hitIds=Game.serverEnemies.filter(e=>!e.dead&&Math.hypot(e.x-x,e.y-y)<r+e.radius).map(e=>e.id);
    if(hitIds.length>0) sendHit(hitIds, dmg / (LocalPlayer.dmgMult||1));
  }
  effects.push({type:'ring',x,y,r:0,maxR:r,color,life:30,maxLife:30});
}

// ─── WEBSOCKET ────────────────────────────────────────────────────────────────
let ws = null;
function connect(onOpen) {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  const url = `${proto}//${location.host}`;
  showConnecting(true, 'CONNECTING...');
  ws = new WebSocket(url);
  ws.onopen = () => { showConnecting(false); onOpen && onOpen(); };
  ws.onerror = () => { showConnecting(false); setMenuErr('Connection failed. Is the server running?'); };
  ws.onclose = () => { showConnecting(false); handleDisconnect(); };
  ws.onmessage = e => handleMsg(JSON.parse(e.data));
}
function sendMsg(msg) { if(ws && ws.readyState===1) ws.send(JSON.stringify(msg)); }
function showConnecting(show, text='') {
  document.getElementById('connecting').style.display = show ? 'flex' : 'none';
  document.getElementById('connectMsg').textContent = text;
}
function setMenuErr(msg) { document.getElementById('menuErr').textContent = msg; }

