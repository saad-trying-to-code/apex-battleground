.spinner { width:40px; height:40px; border:3px solid #333; border-top-color:#ff4400; border-radius:50%; animation:spin 0.8s linear infinite; }
#connectMsg { color:#aaa; font-size:14px; letter-spacing:4px; }
</style>
</head>
<body>
