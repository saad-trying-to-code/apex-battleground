}
.btn-primary { border-color:#ff4400; color:#ff4400; }
.btn-primary:hover { background:#ff4400; color:#000; box-shadow:0 0 20px #ff4400; }
.btn-secondary { border-color:#4488ff; color:#4488ff; }
.btn-secondary:hover { background:#4488ff; color:#000; box-shadow:0 0 20px #4488ff; }
.btn-green { border-color:#44ff88; color:#44ff88; }
