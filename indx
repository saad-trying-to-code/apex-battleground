}
#menuScreen    { background:radial-gradient(ellipse at center,#0d0010 0%,#000 100%); }
#lobbyScreen   { background:radial-gradient(ellipse at 50% 35%,#080015 0%,#000 80%); display:none; }
#charSelectScreen { background:radial-gradient(ellipse at 50% 35%,#080015 0%,#000 80%); display:none; }
#gameOverScreen { background:radial-gradient(ellipse at center,#0d0010 0%,#000 100%); display:none; }
.big-title { font-size:72px; font-weight:900; letter-spacing:8px; color:#fff; text-shadow:0 0 30px #ff4400,0 0 60px #ff2200; margin-bottom:10px; text-align:center; }
.subtitle  { font-size:18px; letter-spacing:12px; color:#ff6600; text-shadow:0 0 10px #ff6600; margin-bottom:40px; }
.glow-line { width:300px; height:1px; background:linear-gradient(to right,transparent,#ff4400,transparent); margin:20px auto; }
.blink-text { font-size:18px; letter-spacing:6px; color:#fff; opacity:0; animation:blink 1.4s ease-in-out infinite; text-shadow:0 0 15px #00ccff; }
/* Buttons */
.btn {
  padding:14px 40px; background:transparent; border:2px solid; cursor:pointer;
  font-size:15px; letter-spacing:4px; font-family:'Courier New',monospace;
