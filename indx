    const auraCol = PLAYER_AURA[Net.mySlot];

    this.trail.forEach(t=>{
      const[sx,sy]=Camera.worldToScreen(t.x,t.y);
      ctx.globalAlpha=(t.life/15)*0.45; ctx.fillStyle=t.col||col;
      ctx.beginPath();ctx.arc(sx,sy,this.radius*0.7,0,Math.PI*2);ctx.fill();
    });
    ctx.globalAlpha=1;

    const[sx,sy]=Camera.worldToScreen(this.x,this.y);
    const aR=this.rageMode?this.radius*4:this.ironFort?this.radius*3.5:this.radius*2.5;
    const aC=this.rageMode?'rgba(255,60,0,0.35)':this.ironFort?'rgba(255,220,0,0.35)':auraCol;
    const grad=ctx.createRadialGradient(sx,sy,0,sx,sy,aR);
    grad.addColorStop(0,aC); grad.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=grad; ctx.beginPath(); ctx.arc(sx,sy,aR,0,Math.PI*2); ctx.fill();

    if(this.smokeMode&&Math.floor(Game.elapsed/3)%2===0){
      ctx.globalAlpha=0.28; ctx.strokeStyle='#9922cc'; ctx.lineWidth=2;
      ctx.beginPath(); ctx.arc(sx,sy,this.radius,0,Math.PI*2); ctx.stroke(); ctx.globalAlpha=1; return;
    }

    ctx.fillStyle=this.hitFlash>0?'#ffffff':(this.blocking?'#aaddff':col);
    ctx.shadowColor=this.rageMode?'#ff4400':this.ironFort?'#ffcc00':glowCol;
    ctx.shadowBlur=this.dodging||this.rageMode||this.ironFort?28:15;
    ctx.beginPath(); ctx.arc(sx,sy,this.radius,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0;

    ctx.strokeStyle=glowCol; ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(sx,sy); ctx.lineTo(sx+Math.cos(this.facing)*(this.radius+12),sy+Math.sin(this.facing)*(this.radius+12)); ctx.stroke();

    // Nametag
    ctx.fillStyle='#fff'; ctx.font='bold 10px Courier New'; ctx.textAlign='center'; ctx.shadowColor=col; ctx.shadowBlur=6;
    ctx.fillText(`P${Net.mySlot+1}`,sx,sy-this.radius-6); ctx.shadowBlur=0; ctx.textAlign='left';

    if(this.rageMode){
      ctx.strokeStyle=`rgba(255,100,0,${0.4+0.3*Math.sin(Game.elapsed*0.15)})`; ctx.lineWidth=3;
      ctx.beginPath(); ctx.arc(sx,sy,this.radius+8+Math.sin(Game.elapsed*0.2)*3,0,Math.PI*2); ctx.stroke();
    }
    if(this.ironFort){
      ctx.strokeStyle=`rgba(255,220,0,${0.7+0.3*Math.sin(Game.elapsed*0.2)})`; ctx.lineWidth=4;
      ctx.shadowColor='#ffcc00'; ctx.shadowBlur=15;
      ctx.beginPath(); ctx.arc(sx,sy,this.radius+10,0,Math.PI*2); ctx.stroke(); ctx.shadowBlur=0;
    }
    if(this.blocking){
      ctx.strokeStyle='rgba(68,136,255,0.6)'; ctx.lineWidth=4;
      ctx.beginPath(); ctx.arc(sx,sy,this.radius+8,0,Math.PI*2); ctx.stroke();
    }
  }
};

