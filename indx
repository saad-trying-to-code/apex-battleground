// ─── REMOTE PLAYERS ───────────────────────────────────────────────────────────
function drawRemotePlayers(serverPlayers) {
  for (const [id, p] of Object.entries(serverPlayers)) {
    if (id === Net.myId) continue;
    const [sx, sy] = Camera.worldToScreen(p.x, p.y);
    const col = PLAYER_COLORS[p.slot] || '#ffffff';
    const glowCol = PLAYER_GLOW[p.slot] || '#aaaaff';

    if (p.dead) continue;
    if (p.smokeMode && Math.floor(Game.elapsed/3)%2===0) {
      ctx.globalAlpha=0.18; ctx.strokeStyle='#9922cc'; ctx.lineWidth=2;
      ctx.beginPath(); ctx.arc(sx,sy,18,0,Math.PI*2); ctx.stroke(); ctx.globalAlpha=1; continue;
    }

    // Aura
    const aR = p.ironFort?63:p.rageMode?72:45;
    const aC = p.rageMode?'rgba(255,60,0,0.25)':p.ironFort?'rgba(255,220,0,0.25)':`rgba(${parseInt(col.slice(1,3),16)},${parseInt(col.slice(3,5),16)},${parseInt(col.slice(5,7),16)},0.15)`;
    const grad = ctx.createRadialGradient(sx,sy,0,sx,sy,aR);
    grad.addColorStop(0,aC); grad.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=grad; ctx.beginPath(); ctx.arc(sx,sy,aR,0,Math.PI*2); ctx.fill();

    ctx.fillStyle = col;
    ctx.shadowColor = p.rageMode?'#ff4400':p.ironFort?'#ffcc00':glowCol;
    ctx.shadowBlur = 15;
    ctx.beginPath(); ctx.arc(sx,sy,18,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0;

    // Direction
    ctx.strokeStyle=glowCol; ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(sx,sy); ctx.lineTo(sx+Math.cos(p.angle||0)*30,sy+Math.sin(p.angle||0)*30); ctx.stroke();

    // Nametag
    ctx.fillStyle='#fff'; ctx.font='bold 10px Courier New'; ctx.textAlign='center'; ctx.shadowColor=col; ctx.shadowBlur=6;
    ctx.fillText(`P${p.slot+1}`,sx,sy-24); ctx.shadowBlur=0; ctx.textAlign='left';

    // HP bar above
    const bw=44, bh=4, bx=sx-bw/2, by=sy-30;
    ctx.fillStyle='#333'; ctx.fillRect(bx,by,bw,bh);
    ctx.fillStyle=col; ctx.fillRect(bx,by,bw*(p.hp/p.maxHp),bh);
    if(p.ironFort){
      ctx.strokeStyle=`rgba(255,220,0,0.8)`; ctx.lineWidth=3;
      ctx.beginPath(); ctx.arc(sx,sy,22,0,Math.PI*2); ctx.stroke();
    }
  }
}

// ─── SERVER ENEMIES DRAW ──────────────────────────────────────────────────────
function drawServerEnemies(enemies) {
  enemies.forEach(e => {
    const [sx, sy] = Camera.worldToScreen(e.x, e.y);
    ctx.globalAlpha = e.dead ? (e.deathTimer||0)/30 : 1;
    if(e.tier===3){
      const g=0.5+0.5*Math.sin(e.glowPhase||0);
      ctx.shadowColor='#ff0000'; ctx.shadowBlur=20+g*20;
      ctx.strokeStyle=`rgba(255,${50+g*100},0,${0.5+g*0.5})`; ctx.lineWidth=3;
      ctx.beginPath(); ctx.arc(sx,sy,e.radius+6,0,Math.PI*2); ctx.stroke();
    }
    if(e.slowed&&!e.dead){
      ctx.strokeStyle='rgba(136,221,255,0.6)'; ctx.lineWidth=2; ctx.setLineDash([3,3]);
      ctx.beginPath(); ctx.arc(sx,sy,e.radius+5,0,Math.PI*2); ctx.stroke(); ctx.setLineDash([]);
    }
    ctx.fillStyle=e.hitFlash>0?'#ffffff':e.color;
    ctx.shadowColor=e.color; ctx.shadowBlur=e.tier===3?15:8;
    ctx.beginPath(); ctx.arc(sx,sy,e.radius,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0;
    if(!e.dead&&e.hp<e.maxHp){
      const bw=e.radius*2.5,bh=4,bx=sx-bw/2,by=sy-e.radius-10;
      ctx.fillStyle='#333'; ctx.fillRect(bx,by,bw,bh);
      const pct=e.hp/e.maxHp;
      ctx.fillStyle=pct>0.5?'#44ff44':pct>0.25?'#ffaa00':'#ff2200';
      ctx.fillRect(bx,by,bw*pct,bh);
    }
    if(e.state==='STAGGER'){
      ctx.fillStyle='rgba(255,255,255,0.5)'; ctx.font='10px Courier New'; ctx.textAlign='center';
      ctx.fillText('✦',sx,sy-e.radius-14); ctx.textAlign='left';
    }
    ctx.globalAlpha=1;
  });
}

// ─── WORLD DRAW ───────────────────────────────────────────────────────────────
function drawWorld() {
  ctx.fillStyle='#08080f'; ctx.fillRect(0,0,canvas.width,canvas.height);
  const tS=80, stx=Math.floor(Camera.x/tS)*tS, sty=Math.floor(Camera.y/tS)*tS;
  for(let tx=stx;tx<Camera.x+canvas.width+tS;tx+=tS){
    for(let ty=sty;ty<Camera.y+canvas.height+tS;ty+=tS){
      if(tx<ARENA_MARGIN||tx>WORLD_W-ARENA_MARGIN||ty<ARENA_MARGIN||ty>WORLD_H-ARENA_MARGIN)continue;
      const[sx,sy]=Camera.worldToScreen(tx,ty);
      ctx.strokeStyle='#111118'; ctx.lineWidth=1; ctx.strokeRect(sx,sy,tS,tS);
      if((Math.floor(tx/tS)+Math.floor(ty/tS))%2===0){ctx.fillStyle='rgba(255,255,255,0.008)';ctx.fillRect(sx,sy,tS,tS);}
    }
  }
  const[ax,ay]=Camera.worldToScreen(ARENA_MARGIN,ARENA_MARGIN);
  ctx.strokeStyle='#ff440044'; ctx.lineWidth=4; ctx.shadowColor='#ff4400'; ctx.shadowBlur=10;
  ctx.strokeRect(ax,ay,WORLD_W-ARENA_MARGIN*2,WORLD_H-ARENA_MARGIN*2); ctx.shadowBlur=0;
  obstacles.forEach(o=>{
    const[sx,sy]=Camera.worldToScreen(o.x,o.y);
    if(sx<-100||sx>canvas.width+100||sy<-100||sy>canvas.height+100)return;
    ctx.fillStyle='#1c1c28'; ctx.strokeStyle='#333344'; ctx.lineWidth=2;
    ctx.shadowColor='#000030'; ctx.shadowBlur=10;
    ctx.beginPath(); ctx.arc(sx,sy,o.r,0,Math.PI*2); ctx.fill(); ctx.stroke(); ctx.shadowBlur=0;
    ctx.strokeStyle='#252535'; ctx.lineWidth=1; ctx.beginPath(); ctx.arc(sx,sy,o.r*0.6,0,Math.PI*2); ctx.stroke();
    ctx.strokeStyle='#2a2a3a';
    for(let c=0;c<3;c++){
      const a=(c*Math.PI*2/3)+o.x*0.01;
      ctx.beginPath(); ctx.moveTo(sx+Math.cos(a)*o.r*0.3,sy+Math.sin(a)*o.r*0.3);
      ctx.lineTo(sx+Math.cos(a+0.4)*o.r*0.8,sy+Math.sin(a+0.4)*o.r*0.8); ctx.stroke();
    }
  });
  // Meteor indicators
  delayed.forEach(d=>{
    const[sx,sy]=Camera.worldToScreen(d.x,d.y);
    const p=0.5+0.5*Math.sin(Game.elapsed*0.3);
    ctx.strokeStyle=`rgba(255,100,0,${0.3+p*0.4})`; ctx.lineWidth=2; ctx.setLineDash([8,4]);
    ctx.beginPath(); ctx.arc(sx,sy,d.r,0,Math.PI*2); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle=`rgba(255,60,0,${0.06+p*0.08})`; ctx.beginPath(); ctx.arc(sx,sy,d.r,0,Math.PI*2); ctx.fill();
    ctx.strokeStyle=`rgba(255,150,0,${0.6+p*0.3})`; ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(sx-15,sy-15); ctx.lineTo(sx+15,sy+15); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(sx+15,sy-15); ctx.lineTo(sx-15,sy+15); ctx.stroke();
  });
}

function drawProjectiles() {
  projectiles.forEach(p=>{
    const[sx,sy]=Camera.worldToScreen(p.x,p.y);
    ctx.fillStyle=p.color; ctx.shadowColor=p.color; ctx.shadowBlur=15;
    ctx.beginPath(); ctx.arc(sx,sy,p.rad,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0;
    for(let t=1;t<=3;t++){
      ctx.globalAlpha=(1-t/3)*0.4; ctx.beginPath();
      ctx.arc(sx-p.vx*t*1.5,sy-p.vy*t*1.5,p.rad*(1-t/3),0,Math.PI*2); ctx.fill();
    }
    ctx.globalAlpha=1;
  });
}

