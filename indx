    } else { this.trail=this.trail.filter(t=>{t.life--;return t.life>0;}); }

    if(this.attackCooldown>0) this.attackCooldown--;
    if(this.comboTimer>0){if(--this.comboTimer<=0)this.comboStep=0;}
    if(this.dodgeCooldown>0) this.dodgeCooldown--;
    for(const k of['Q','E','R']) if(this.skills[k]>0) this.skills[k]--;
    if(this.hitFlash>0) this.hitFlash--;
    if(this.invincible>0) this.invincible--;
    if(!this.dodging) this.stamina=Math.min(this.maxStamina,this.stamina+0.3);
    if(this.rageMode&&--this.rageTimer<=0){this.rageMode=false;this.dmgMult/=2;}
    if(this.smokeMode&&--this.smokeTimer<=0) this.smokeMode=false;
    if(this.ironFort&&--this.ironTimer<=0) this.ironFort=false;
