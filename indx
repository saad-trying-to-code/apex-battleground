.stat-row .val { color:#ff6600; }
#finalScoreboard { margin:16px 0; }
.score-row { display:flex; gap:16px; align-items:center; padding:10px 20px; border-radius:6px; margin:6px 0; background:rgba(255,255,255,0.04); border:1px solid #1a1a1a; }
